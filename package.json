{
  "name": "@yerba-buena/flowhub-client",
  "version": "0.0.1",
  "description": "Unofficial TypeScript client for the Flowhub API",
  "keywords": [
    "flowhub",
    "cannabis",
    "dispensary",
    "pos",
    "api-client"
  ],
  "license": "MIT",
  "author": "Yerba Buena Brands, LLC",
  "homepage": "https://github.com/yerba-buena/flowhub-client-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yerba-buena/flowhub-client-ts.git"
  },
  "bugs": {
    "url": "https://github.com/yerba-buena/flowhub-client-ts/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./dashboard": {
      "import": {
        "types": "./dist/dashboard/index.d.ts",
        "default": "./dist/dashboard/index.js"
      },
      "require": {
        "types": "./dist/dashboard/index.d.cts",
        "default": "./dist/dashboard/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "DISCLAIMER.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "publint": "publint",
    "attw": "attw --pack .",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build && npm run publint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "msw": "^2.6.0",
    "publint": "^0.3.21",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
