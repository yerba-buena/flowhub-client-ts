# Copy this file to .env and fill in the values.
# .env is gitignored — never commit credentials.

# Public Flowhub API (Inventory, Locations, Orders)
# Get these from Flowhub when you request API access.
FLOWHUB_CLIENT_ID=
FLOWHUB_API_KEY=

# Order Ahead OAuth2 (via Auth0)
# Flowhub issues a separate Auth0 client_id/secret pair for Order Ahead access.
# These are NOT the same as FLOWHUB_CLIENT_ID/FLOWHUB_API_KEY above.
FLOWHUB_AUTH0_CLIENT_ID=
FLOWHUB_AUTH0_CLIENT_SECRET=

# Internal client (reverse-engineered endpoints: CSV reports, cash management)
# Use a dedicated Flowhub user account with the "Analytics Only" role —
# don't use personal credentials. See src/internal/README.md for security
# guidance.
#
# NOTE: These are just the conventional names used by the examples/tests — the
# library itself does not read env vars; you pass email/password to the client.
# The legacy FLOWHUB_DASHBOARD_* names are still accepted by the test suite.
FLOWHUB_INTERNAL_EMAIL=
FLOWHUB_INTERNAL_PASSWORD=
FLOWHUB_INTERNAL_STORE_ID=
