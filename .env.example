# Copy this file to .env and fill in the values.
# .env is gitignored — never commit credentials.

# Public Flowhub API (Inventory, Locations, Orders)
# Get these from Flowhub when you request API access.
FLOWHUB_CLIENT_ID=
FLOWHUB_API_KEY=

# Order Ahead OAuth2 (via Auth0)
# Flowhub issues a separate Auth0 client_id/secret pair for Order Ahead access.
# These are NOT the same as FLOWHUB_CLIENT_ID/FLOWHUB_API_KEY above.
FLOWHUB_AUTH0_CLIENT_ID=
FLOWHUB_AUTH0_CLIENT_SECRET=

# Dashboard client (reverse-engineered CSV report downloads)
# Use a dedicated Flowhub user account with the "Analytics Only" role —
# don't use personal credentials. See src/dashboard/README.md for security
# guidance.
FLOWHUB_DASHBOARD_EMAIL=
FLOWHUB_DASHBOARD_PASSWORD=
FLOWHUB_DASHBOARD_STORE_ID=
